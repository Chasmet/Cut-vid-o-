<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="7dp">

    <FrameLayout
        android:id="@+id/thumbnailFrame"
        android:layout_width="match_parent"
        android:layout_height="152dp">

        <ImageView
            android:id="@+id/thumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/surface_alt"
            android:contentDescription="@string/play_video"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_video" />

        <CheckBox
            android:id="@+id/selectionCheck"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_gravity="start|top"
            android:buttonTint="@color/share_checkbox_tint"
            android:contentDescription="@string/select_video"
            android:gravity="center"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/gridMoreButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="end|top"
            android:background="@drawable/bg_grid_action"
            android:contentDescription="@string/more_actions"
            android:padding="10dp"
            android:src="@drawable/ic_more" />
    </FrameLayout>

    <TextView
        android:id="@+id/nameText"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="6dp"
        android:ellipsize="middle"
        android:fontFamily="sans-serif-medium"
        android:gravity="center_vertical"
        android:maxLines="2"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/detailsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/gridScheduleButton"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="7dp"
        android:background="@drawable/bg_schedule_button"
        android:clickable="true"
        android:drawableStart="@drawable/ic_calendar"
        android:drawablePadding="5dp"
        android:focusable="true"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:text="@string/plan_publication_short"
        android:textColor="@color/white"
        android:textSize="9sp" />
</LinearLayout>
