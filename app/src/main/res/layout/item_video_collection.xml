<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="136dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="10dp">

    <ImageView
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:background="@drawable/bg_primary_button"
        android:contentDescription="@string/video_collection"
        android:padding="11dp"
        android:src="@drawable/ic_folder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="@string/collection_label"
            android:textColor="@color/teal"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/collectionNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:textColor="@color/white"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/collectionDetailsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="44dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/renameCollectionButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/transparent"
            android:contentDescription="@string/rename_collection"
            android:padding="12dp"
            android:src="@drawable/ic_edit" />

        <ImageButton
            android:id="@+id/shareCollectionButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/transparent"
            android:contentDescription="@string/share_collection"
            android:padding="12dp"
            android:src="@drawable/ic_share" />

        <ImageButton
            android:id="@+id/deleteCollectionButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/transparent"
            android:contentDescription="@string/delete_collection"
            android:padding="11dp"
            android:src="@drawable/ic_delete" />
    </LinearLayout>
</LinearLayout>
