<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="13dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/platformText"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_mode_selected"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:minWidth="88dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:gravity="end"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/scheduleTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="11dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="2"
        android:textColor="@color/white"
        android:textSize="17sp" />

    <TextView
        android:id="@+id/dateText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:textColor="@color/teal"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/visibilityText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/metadataText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_input"
        android:ellipsize="end"
        android:maxLines="4"
        android:padding="10dp"
        android:textColor="@color/white"
        android:textSize="12sp" />

    <CheckBox
        android:id="@+id/publishedCheck"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:buttonTint="@color/share_checkbox_tint"
        android:text="@string/mark_as_published"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/publishButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_primary_button"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/white"
            android:textSize="11sp" />

        <ImageButton
            android:id="@+id/editButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="5dp"
            android:background="@color/transparent"
            android:contentDescription="@string/edit_schedule"
            android:padding="10dp"
            android:src="@drawable/ic_edit" />

        <ImageButton
            android:id="@+id/duplicateButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/transparent"
            android:contentDescription="@string/duplicate_schedule"
            android:padding="10dp"
            android:src="@drawable/ic_duplicate" />

        <ImageButton
            android:id="@+id/copyButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/transparent"
            android:contentDescription="@string/copy_metadata"
            android:padding="10dp"
            android:src="@drawable/ic_copy" />

        <ImageButton
            android:id="@+id/deleteButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/transparent"
            android:contentDescription="@string/delete_schedule"
            android:padding="10dp"
            android:src="@drawable/ic_delete" />
    </LinearLayout>
</LinearLayout>
