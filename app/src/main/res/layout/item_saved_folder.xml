<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="116dp"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="8dp">

    <ImageView
        android:id="@+id/folderIcon"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/bg_mode_selected"
        android:contentDescription="@string/video_folder"
        android:padding="11dp"
        android:src="@drawable/ic_folder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="13dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/folderNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:textColor="@color/white"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/folderDetailsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/teal"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/folderDateText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="44dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/noteButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/transparent"
            android:contentDescription="@string/edit_folder_note"
            android:padding="11dp"
            android:src="@drawable/ic_note" />

        <ImageButton
            android:id="@+id/moreButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/transparent"
            android:contentDescription="@string/more_actions"
            android:padding="11dp"
            android:src="@drawable/ic_more" />
    </LinearLayout>
</LinearLayout>
